    "businessPages": {
      "privacy": {
        "enabled": true,
        "content": "This demo application is not cloud hosted, and runs entirely on your desktop.  It installs a local database for long term storage of medical data.  Some data may not be stored encrypted at rest in early versions of this demo.  Although passing HealthIT (g)(10) compliance and supporting multi-user access and audit trails, this app release does not currently make any claims or warrants to be HIPAA compliant."
      },
      "terms": {
        "enabled": true,
        "content": "All rights reserved.  Open-source components of this app can be found online."
      },
      "about": {
        "enabled": true,
        "content": "Brought to you by Merklis (Merkle Storage), Radical Imaging (Cornerstone3D viewer), and Orbital Health (FHIR server)."
      },
      "support": {
        "enabled": true,
        "content": "Buy a license for support.  Enjoy the free version."
      }
